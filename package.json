{
  "name": "obs-descript-uploader",
  "version": "0.1.0",
  "description": "A desktop relay from OBS recordings to Descript.",
  "author": "OBS Upload",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-electron.cjs && electron-builder install-app-deps",
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on tcp:5173 file:dist-electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder",
    "build:unpacked": "tsc -p tsconfig.main.json && vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.obsdescript.uploader",
    "productName": "OBS Upload",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.468.0",
    "obs-websocket-js": "^5.0.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^38.8.6",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "wait-on": "^8.0.3"
  }
}
